{
  "name": "hono-workers-starter",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "start": "bun index.ts",
    "db:migrate": "bun src/data/migrate.ts",
    "db:migrate:prod": "bun --no-env-file --env-file=.env.production.local src/data/migrate.ts",
    "db:seed": "bun src/data/seed.ts",
    "build:worker": "vite build --config vite.config.build.ts",
    "preview:worker": "vite build --config vite.config.build.ts && wrangler dev",
    "deploy": "vite build --config vite.config.build.ts && wrangler deploy",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write src/ index.ts",
    "fmt:check": "oxfmt --check src/ index.ts",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "hono": "^4.12.9",
    "s3mini": "^0.9.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.10.1",
    "@hono/vite-dev-server": "^0.25.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "vite": "^8.0.3",
    "wrangler": "^4.79.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "bun-create": {
    "postinstall": [],
    "start": "bun run dev"
  }
}
