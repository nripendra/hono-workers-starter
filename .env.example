# Database (Turso)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Preview gate — set a key to enable "Coming Soon" mode on the storefront.
# Share the URL ?allow=<key> to grant access via cookie.
# Leave empty to disable the gate entirely.
PREVIEW_ACCESS_KEY=

# R2 / S3-compatible storage (optional)
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com/your-bucket
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://media.example.com
